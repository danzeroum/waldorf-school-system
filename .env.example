# ============================================================
# Waldorf School System — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# --- Banco de Dados (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=waldorf_db
DB_USER=waldorf
DB_PASS=waldorf123
MYSQL_ROOT_PASSWORD=root_senha_segura

# --- JWT ---
# IMPORTANTE: troque por uma string aleatória de 256 bits em produção
JWT_SECRET=waldorf-jwt-secret-key-change-in-production-256bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# --- MinIO (armazenamento de arquivos) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=waldorf-files

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=waldorf-school-prod
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# --- App ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- Frontend ---
API_URL=http://localhost:8080/api/v1
