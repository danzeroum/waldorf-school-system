# ============================================================
# Waldorf School System — Variáveis de Ambiente
# Copie para .env e preencha com valores reais
# NUNCA commite o arquivo .env
# ============================================================

# --- Banco de Dados (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=waldorf_db
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME
# TLS na conexão com o banco. Use true em produção; em dev local sem TLS, defina false.
DB_USE_SSL=true
DB_ALLOW_PUBKEY=false

# --- JWT ---
# Gere uma string aleatória de no mínimo 256 bits, ex:
#   openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=CHANGE_ME
RABBITMQ_PASS=CHANGE_ME

# --- MinIO (armazenamento de arquivos) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=waldorf-files

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# --- App ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- Segurança / CORS ---
# Origens permitidas (separadas por vírgula). NÃO use IPs/origens de produção em dev.
CORS_ALLOWED_ORIGINS=http://localhost:4200
# Swagger UI público (deixe false em produção)
APP_SWAGGER_PUBLIC=false
# Cookies de sessão (HttpOnly). Em produção (HTTPS) mantenha secure=true.
APP_COOKIE_SECURE=true
APP_COOKIE_SAME_SITE=Strict
# Chave de criptografia para dados sensíveis (CPF). Gere com: openssl rand -hex 32
APP_ENCRYPTION_KEY=CHANGE_ME
# Rate limiting de login
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=60

# --- Frontend ---
API_URL=http://localhost:8080/api/v1
