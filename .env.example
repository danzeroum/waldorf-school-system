# ============================================================
# Waldorf School System — Variáveis de Ambiente
# Copie para .env e preencha com valores reais
# NUNCA commite o arquivo .env
# ============================================================

# --- Banco de Dados (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=waldorf_db
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

# --- JWT ---
# Gere uma string aleatória de no mínimo 256 bits, ex:
#   openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=CHANGE_ME
RABBITMQ_PASS=CHANGE_ME

# --- MinIO (armazenamento de arquivos) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=waldorf-files

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# --- App ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- Frontend ---
API_URL=http://localhost:8080/api/v1
