// === QUINTAL AROEIRA — DESIGN SYSTEM GLOBAL ===

// Tailwind base
@tailwind base;
@tailwind components;
@tailwind utilities;

// === RESET E BASE ===
*, *::before, *::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  margin: 0;
  padding: 0;
  font-family: 'Nunito', system-ui, -apple-system, sans-serif;
  background-color: #F5F0E8; // waldorf-cream-50 (areia)
  color: #3a3835;            // waldorf-gray-800
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

// === TIPOGRAFIA ===
h1, h2, h3 {
  font-family: 'Lora', Georgia, serif;
  font-weight: 600;
  color: #252321; // waldorf-gray-900
  line-height: 1.3;
}

h4, h5, h6 {
  font-family: 'Nunito', sans-serif;
  font-weight: 600;
  color: #3a3835;
}

a {
  color: #5B7F5E;
  text-decoration: none;
  transition: color 0.2s ease;

  &:hover {
    color: #384E3A;
  }
}

// === SCROLLBAR CUSTOMIZADO ===
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: #E0D5C2; // waldorf-cream-200
}

::-webkit-scrollbar-thumb {
  background: #8fae91; // waldorf-green-300
  border-radius: 3px;

  &:hover {
    background: #5B7F5E; // waldorf-green-500
  }
}

// === COMPONENTES REUTILIZÁVEIS (Tailwind @layer) ===
@layer components {

  // --- Botões ---
  .btn-primary {
    @apply bg-waldorf-green-500 text-white font-medium py-2.5 px-6 rounded-xl
           hover:bg-waldorf-green-600 active:bg-waldorf-green-700
           transition-all duration-200 ease-in-out
           focus:outline-none focus:ring-2 focus:ring-waldorf-green-300 focus:ring-offset-2
           disabled:opacity-50 disabled:cursor-not-allowed;
  }

  .btn-secondary {
    @apply bg-waldorf-cream-100 text-waldorf-gray-700 font-medium py-2.5 px-6 rounded-xl
           border border-waldorf-cream-300
           hover:bg-waldorf-cream-200 hover:text-waldorf-gray-800
           active:bg-waldorf-cream-300
           transition-all duration-200 ease-in-out
           focus:outline-none focus:ring-2 focus:ring-waldorf-cream-300 focus:ring-offset-2;
  }

  .btn-ghost {
    @apply text-waldorf-gray-600 font-medium py-2 px-4 rounded-xl
           hover:bg-waldorf-cream-100 hover:text-waldorf-gray-800
           transition-all duration-200 ease-in-out;
  }

  .btn-icon {
    @apply p-2 rounded-xl text-waldorf-gray-500
           hover:bg-waldorf-cream-100 hover:text-waldorf-gray-700
           transition-all duration-200 ease-in-out;
  }

  .btn-danger {
    @apply bg-red-500 text-white font-medium py-2.5 px-6 rounded-xl
           hover:bg-red-600 active:bg-red-700
           transition-all duration-200 ease-in-out;
  }

  // --- Cards ---
  .card {
    @apply bg-white rounded-2xl border border-waldorf-cream-200
           shadow-waldorf-sm p-5;
  }

  .card-hover {
    @apply card hover:shadow-waldorf-md hover:border-waldorf-cream-300
           transition-all duration-200 ease-in-out cursor-pointer;
  }

  // --- Formulários ---
  .form-input {
    @apply w-full px-4 py-2.5 rounded-xl border border-waldorf-cream-300
           bg-white text-waldorf-gray-800 placeholder-waldorf-gray-400
           focus:outline-none focus:ring-2 focus:ring-waldorf-green-300
           focus:border-waldorf-green-400
           transition-all duration-200 ease-in-out;
  }

  .form-input-error {
    @apply form-input border-red-400 focus:ring-red-300 focus:border-red-400;
  }

  .form-label {
    @apply block text-sm font-medium text-waldorf-gray-700 mb-1.5;
  }

  .form-error {
    @apply text-xs text-red-500 mt-1;
  }

  // --- Badges de status ---
  .badge {
    @apply inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium;
  }

  .badge-success {
    @apply badge bg-waldorf-green-100 text-waldorf-green-700;
  }

  .badge-warning {
    @apply badge bg-waldorf-amber-100 text-waldorf-amber-700;
  }

  .badge-danger {
    @apply badge bg-red-100 text-red-700;
  }

  .badge-info {
    @apply badge bg-blue-100 text-blue-700;
  }

  .badge-neutral {
    @apply badge bg-waldorf-gray-100 text-waldorf-gray-600;
  }

  // --- Sidebar ---
  .sidebar-link {
    @apply flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium
           text-waldorf-gray-600 hover:bg-waldorf-green-50 hover:text-waldorf-green-700
           transition-all duration-200 ease-in-out cursor-pointer;
  }

  .sidebar-link-active {
    @apply sidebar-link bg-waldorf-green-50 text-waldorf-green-700
           border-l-4 border-waldorf-green-500;
  }

  // --- Tabelas ---
  .table-header {
    @apply text-xs font-semibold text-waldorf-gray-500 uppercase tracking-wide
           bg-waldorf-cream-50 px-4 py-3 border-b border-waldorf-cream-200;
  }

  .table-cell {
    @apply px-4 py-3 text-sm text-waldorf-gray-700 border-b border-waldorf-cream-100;
  }

  .table-row-hover {
    @apply hover:bg-waldorf-cream-50 transition-colors duration-150;
  }

  // --- Aspect Tags (observações Waldorf) ---
  .aspect-fisico      { @apply bg-green-100  text-green-700;  }
  .aspect-animico     { @apply bg-blue-100   text-blue-700;   }
  .aspect-espiritual  { @apply bg-indigo-100 text-indigo-700; }
  .aspect-cognitivo   { @apply bg-orange-100 text-orange-700; }
  .aspect-social      { @apply bg-red-100    text-red-700;    }
  .aspect-artistico   { @apply bg-purple-100 text-purple-700; }
  .aspect-manual      { @apply bg-amber-100  text-amber-700;  }

  // --- Loading skeleton ---
  .skeleton {
    @apply bg-waldorf-cream-200 animate-pulse rounded;
  }

  // --- Divider ---
  .divider {
    @apply border-t border-waldorf-cream-200 my-6;
  }
}

// === ANIMAÇÕES CUSTOM ===
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-16px); }
  to   { opacity: 1; transform: translateX(0); }
}

.animate-fade-in-up  { animation: fadeInUp  0.3s ease-out both; }
.animate-fade-in     { animation: fadeIn    0.25s ease-out both; }
.animate-slide-left  { animation: slideInLeft 0.25s ease-out both; }

// === MATERIAL ANGULAR — OVERRIDE TEMA ===
.mat-mdc-card {
  border-radius: 1rem !important;
  border: 1px solid #E0D5C2 !important;
  box-shadow: 0 1px 3px rgba(91,127,94,0.08), 0 1px 2px rgba(0,0,0,0.06) !important;
}

.mat-mdc-raised-button.mat-primary {
  background-color: #5B7F5E !important;
  border-radius: 0.75rem !important;
}

.mat-mdc-form-field.mat-focused .mdc-notched-outline__leading,
.mat-mdc-form-field.mat-focused .mdc-notched-outline__notch,
.mat-mdc-form-field.mat-focused .mdc-notched-outline__trailing {
  border-color: #5B7F5E !important;
}

.mat-mdc-checkbox.mat-primary .mdc-checkbox__native-control:enabled:checked ~ .mdc-checkbox__background {
  background-color: #5B7F5E !important;
  border-color: #5B7F5E !important;
}

.mat-mdc-progress-spinner circle {
  stroke: #5B7F5E !important;
}
