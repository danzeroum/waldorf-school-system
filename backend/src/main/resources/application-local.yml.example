# Profile para desenvolvimento local
# Copie para application-local.yml e preencha com suas credenciais locais
# NUNCA commite application-local.yml
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/waldorf_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
    username: CHANGE_ME
    password: CHANGE_ME

  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true

waldorf:
  storage:
    type: local
    local:
      upload-dir: ./uploads

logging:
  level:
    br.edu.waldorf: DEBUG
